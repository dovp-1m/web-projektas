Options -Indexes
Options +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve static assets directly (no framework overhead)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through CodeIgniter index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

# Security: deny access to hidden files and application folder
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
